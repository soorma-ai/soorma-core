# Soorma Platform (required)
REGISTRY_URL=http://localhost:8081
EVENT_BUS_URL=nats://localhost:4222
MEMORY_URL=http://localhost:8083
TENANT_ID=demo-tenant
USER_ID=demo-user

# LLM provider — used by router to select the right worker event
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LLM model for event selection (optional — defaults to gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini
