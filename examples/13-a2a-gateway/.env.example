# Soorma services (running via `soorma dev` or docker-compose)
SOORMA_EVENT_SERVICE_URL=http://localhost:8082
SOORMA_REGISTRY_URL=http://localhost:8081

# Multi-tenancy — obtain from the Soorma developer portal
SOORMA_DEVELOPER_TENANT_ID=00000000-0000-0000-0000-000000000001
SOORMA_USER_ID=00000000-0000-0000-0000-000000000002

# A2A gateway endpoint — change if running behind a proxy / in a different environment
GATEWAY_URL=http://localhost:9000
GATEWAY_PORT=9000
